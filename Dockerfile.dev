# syntax=docker/dockerfile:1

# Imagem de desenvolvimento: roda o dev server do Vite com HMR.
# O código-fonte é montado via bind mount no docker-compose (serviço "dev").
FROM node:22-alpine
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

EXPOSE 5173
# --host expõe o servidor para fora do container.
CMD ["npm", "run", "dev", "--", "--host"]
